generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "sqlite"
}

enum ModelMode {
    local
    cloud
    hybrid
}

enum MessageRole {
    user
    assistant
    system
}

model User {
    id   String @id @default(cuid())
    name String

    profileComplete Boolean @default(false)

    settings      Settings?
    contacts      Contact[]
    conversations Conversation[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Settings {
    id String @id @default(cuid())

    userId String @unique
    user   User   @relation(fields: [userId], references: [id])

    setupCompleted Boolean @default(false)

    /**
     * LLM config
     */
    /**
     * /**
     * /**
     * /**
     * /**
     * /**
     * /**
     * /*
     * LLM config
     */
    modelMode ModelMode @default(local)

    // ollama
    localModel          String?
    localModelInstalled Boolean @default(false)

    // whisper
    whisperModel String?

    geminiApiKeyEnc String?

    /**
     * Email (optional SMTP fallback)
     */
    email               String?
    emailAppPasswordEnc String?

    /**
     * Search
     */
    searchApiKeyEnc String?

    /**
     * Google OAuth
     */
    googleId              String?
    googleRefreshTokenEnc String?
    googleClientSecret    String?
    googleTokenExpiry     DateTime?
    googleConnectedAt     DateTime?

    /**
     * Spotify OAuth
     */

    spotifyAuthComplete    Boolean   @default(false)
    spotifyUserId          String?
    spotifyAccessTokenEnc  String?
    spotifyRefreshTokenEnc String?
    spotifyTokenExpiry     DateTime?
    spotifyConnectedAt     DateTime?

    /**
     * WhatsApp (Baileys)
     */
    whatsappLinked      Boolean @default(false)
    whatsappSessionPath String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Contact {
    id String @id @default(cuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    googleId String? @unique

    name        String
    phoneNumber String?
    email       String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Conversation {
    id String @id @default(cuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    title    String?
    messages Message[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Message {
    id String @id @default(cuid())

    conversationId String
    conversation   Conversation @relation(fields: [conversationId], references: [id])

    role    MessageRole
    content String

    createdAt DateTime @default(now())
}
